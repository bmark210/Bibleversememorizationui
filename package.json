    "@types/pg": "^8.10.2",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/swagger-ui-react": "^5.18.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "openapi-typescript-codegen": "^0.30.0",
    "prisma": "^7.2.0",
    "tailwindcss": "4.1.12",
    "tsx": "^4.21.0",
    "typescript": "5.7.2"
  }
}
