{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:clean": "node scripts/clean-next.mjs && next dev",
    "build": "node scripts/clean-next.mjs && next build",
    "start": "next start",
    "lint": "eslint src/ --max-warnings 0",
    "generate-api": "tsx scripts/generate-openapi.ts && npx openapi-typescript-codegen --input openapi.json --output src/api --client axios && npx openapi-typescript openapi-oas3.json -o src/api/openapi-types.ts",
    "generate-api:fetch": "tsx scripts/generate-openapi.ts",
    "generate-api:codegen": "npx openapi-typescript-codegen --input openapi.json --output src/api --client axios",
    "generate-api:types": "npx openapi-typescript openapi-oas3.json -o src/api/openapi-types.ts",
    "telegram:webhook": "tsx scripts/register-telegram-webhook.ts",
    "telegram:webhook:dev": "tsx scripts/register-telegram-webhook_forDev.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@tailwindcss/oxide": "^4.1.12",
    "@tailwindcss/postcss": "4.1.12",
    "@use-gesture/react": "^10.3.1",
    "axios": "^1.13.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lightningcss": "^1.30.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next": "^14.2.35",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.18.1",
    "sonner": "^2.0.7",
    "swagger-ui-react": "^5.31.0",
    "tailwind-merge": "3.2.0",
    "tailwindcss": "4.1.12",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/pg": "^8.10.2",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/swagger-ui-react": "^5.18.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "openapi-typescript": "^7.13.0",
    "openapi-typescript-codegen": "^0.30.0",
    "swagger2openapi": "^7.0.8",
    "tsx": "^4.21.0",
    "typescript": "5.7.2"
  }
}
