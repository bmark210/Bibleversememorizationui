generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Translation {
  NRT
  SYNOD
  RBS2
  BTI
}

enum VerseStatus {
  MY
  LEARNING
  STOPPED
}

model User {
  id           String      @id @default(cuid())
  telegramId   String      @unique
  name         String?
  nickname     String?
  avatarUrl    String?
  translation  Translation @default(SYNOD)
  createdAt    DateTime    @default(now())

  // Максимальное количество дней
  dailyStreak         Int @default(0)

  verses       UserVerse[]
  following    UserFollow[] @relation("UserFollowing")
  followers    UserFollow[] @relation("UserFollowers")
}

model UserFollow {
  id                  String   @id @default(cuid())
  followerTelegramId  String
  followingTelegramId String
  createdAt           DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerTelegramId], references: [telegramId], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingTelegramId], references: [telegramId], onDelete: Cascade)

  @@unique([followerTelegramId, followingTelegramId])
  @@index([followerTelegramId, createdAt])
  @@index([followingTelegramId])
}

// Глобальный каталог стихов — один стих существует в системе один раз,
// независимо от того, сколько пользователей его добавили себе.
model Verse {
  id              String   @id @default(cuid())
  externalVerseId String   @unique // "43-3-16" в формате "book-chapter-verse"

  createdAt       DateTime @default(now())

  userVerses      UserVerse[]
  tags            VerseTag[]
}

// Личный стих пользователя — факт что пользователь добавил стих к себе
// + весь его индивидуальный прогресс. Удаление этой записи не затрагивает
// глобальный Verse и прогресс других пользователей.
model UserVerse {
  id         Int    @id @default(autoincrement())
  telegramId String // Actual Telegram ID
  verseId    String // FK → Verse.id

  status     VerseStatus @default(MY)

  masteryLevel       Int       @default(0)
  repetitions        Int       @default(0)
  referenceScore     Int       @default(50)
  incipitScore       Int       @default(50)
  lastTrainingModeId Int?
  lastReviewedAt     DateTime?
  nextReviewAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [telegramId], references: [telegramId])
  verse Verse @relation(fields: [verseId], references: [id])

  @@unique([telegramId, verseId])
}

model Tag {
  id        String   @id @default(cuid())
  slug      String   @unique // faith, love, hope
  title     String   @unique // Вера, Любовь, Надежда
  createdAt DateTime @default(now())

  verses VerseTag[]
}

// Теги принадлежат глобальному стиху, а не конкретному пользователю.
model VerseTag {
  id      String @id @default(cuid())
  verseId String // FK → Verse.id
  tagId   String

  verse Verse @relation(fields: [verseId], references: [id])
  tag   Tag   @relation(fields: [tagId], references: [id])

  @@unique([verseId, tagId])
}
